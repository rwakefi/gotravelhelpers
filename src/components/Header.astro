---
import { site, nav } from '../data/site';

interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
---

<header class:list={['header', transparent && 'header--transparent']} id="site-header">
  <div class="container header__inner">
    <a href="/" class="header__logo">
      <img
        src={site.logo.src}
        alt={site.logo.alt}
        width={site.logo.width}
        height={site.logo.height}
        loading="eager"
        decoding="async"
      />
    </a>
    <nav class="header__nav" aria-label="Main navigation">
      {
        nav.map((item) => (
          <a href={item.href} class="header__link">
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="header__actions">
      <a href={site.phoneHref} class="header__cta btn btn--primary">
        {site.phone}
      </a>
      <button class="header__menu-btn" aria-label="Open menu" aria-expanded="false" id="menu-btn">
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
  <nav class="header__mobile" id="mobile-nav" aria-label="Mobile navigation" hidden>
    {
      nav.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))
    }
    <a href="/contact" class="btn btn--primary">Get a Quote</a>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header');
  const menuBtn = document.getElementById('menu-btn');
  const mobileNav = document.getElementById('mobile-nav');

  const updateHeader = () => {
    if (!header?.classList.contains('header--transparent')) return;
    header.classList.toggle('header--scrolled', window.scrollY > 24);
  };

  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileNav?.hasAttribute('hidden') === false;
    if (isOpen) {
      mobileNav?.setAttribute('hidden', '');
      menuBtn?.setAttribute('aria-expanded', 'false');
    } else {
      mobileNav?.removeAttribute('hidden');
      menuBtn?.setAttribute('aria-expanded', 'true');
    }
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(20, 20, 20, 0.06);
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease;
  }

  .header--transparent {
    background: transparent;
    backdrop-filter: none;
    border-bottom-color: transparent;
    box-shadow: none;
  }

  .header--transparent.header--scrolled {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(14px);
    border-bottom-color: rgba(20, 20, 20, 0.06);
    box-shadow: 0 1px 0 rgba(20, 20, 20, 0.04);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    height: var(--header-height);
  }

  .header__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .header__logo img {
    display: block;
    width: clamp(9rem, 16vw, 13rem);
    height: auto;
    max-height: calc(var(--header-height) - 0.65rem);
    object-fit: contain;
  }

  .header__nav {
    display: none;
    align-items: center;
    gap: 1.75rem;
    margin-left: auto;
    margin-right: auto;
  }

  .header__link {
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--color-text-muted);
    white-space: nowrap;
    transition: color 0.2s;
  }

  .header--transparent:not(.header--scrolled) .header__link {
    color: rgba(20, 20, 20, 0.75);
  }

  .header__link:hover {
    color: var(--color-text);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .header__cta {
    display: none;
    font-size: 0.875rem;
    padding: 0.6rem 1.35rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .header__menu-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
  }

  .header__menu-btn span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-text);
  }

  .header__mobile {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    border-top: 1px solid var(--color-border);
    background: #fff;
  }

  .header__mobile a {
    font-size: 1.05rem;
    padding: 0.25rem 0;
  }

  @media (min-width: 960px) {
    .header__nav {
      display: flex;
    }

    .header__cta {
      display: inline-flex;
    }

    .header__menu-btn {
      display: none;
    }

    .header__mobile {
      display: none !important;
    }
  }
</style>
