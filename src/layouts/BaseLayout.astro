---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description?: string;
  /** Path to a social-share image, relative to the site root (e.g. /images/foo.jpg). */
  image?: string;
  /** og:type — "website" for most pages, "article" for posts. */
  type?: string;
  /** Set true to keep a page out of search results (e.g. dev/preview pages). */
  noindex?: boolean;
  /** Extra JSON-LD structured data objects to inject for this page. */
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = site.description,
  image = '/images/og-cover.jpg',
  type = 'website',
  noindex = false,
  schema,
} = Astro.props;

const pageTitle = title === site.name ? `${site.name} | ${site.motto}` : `${title} | ${site.name}`;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'TravelAgency',
  '@id': `${Astro.site}#organization`,
  name: site.name,
  url: Astro.site?.href,
  image: ogImage,
  logo: new URL(site.logo.src, Astro.site).href,
  description: site.description,
  slogan: site.motto,
  telephone: site.phoneHref.replace('tel:', ''),
  email: site.email,
  areaServed: 'Worldwide',
  founder: {
    '@type': 'Person',
    name: site.founder.name,
    jobTitle: `${site.founder.title}, ${site.founder.credentials}`,
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.address.city,
    addressRegion: site.address.state,
    addressCountry: 'US',
  },
  sameAs: Object.values(site.social),
};

const schemaList = [organizationSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta name="robots" content="index, follow, max-image-preview:large" />
      )
    }
    <meta name="theme-color" content="#9e3b3b" />
    <meta name="author" content={site.name} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    {
      schemaList.map((entry) => (
        <script type="application/ld+json" set:html={JSON.stringify(entry)} />
      ))
    }
  </head>
  <body class:list={[Astro.url.pathname === '/' && 'page-home']}>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
