---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site, steps, images } from '../data/site';
---

<BaseLayout title="How It Works" description="Learn how Go Travel Helpers plans and delivers door-to-door travel companion support — from first inquiry to safe arrival.">
  <PageHero
    label="The process"
    title="From first call to safe arrival"
    description="We make getting started simple. Tell us about your trip, and we handle the rest — planning, coordination, and companion support every step of the way."
    image={images.pageHero.howItWorks}
  />

  <section class="section">
    <div class="container process-list">
      {
        steps.map((step) => (
          <article class="process-step">
            <span class="process-step__number">{step.number}</span>
            <div>
              <h2>{step.title}</h2>
              <p>{step.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section section--alt">
    <div class="container included">
      <p class="section-label">What's included</p>
      <h2 class="section-title">Support at every stage</h2>
      <div class="grid-2">
        <ul class="included-list">
          <li>Pre-trip planning and itinerary coordination</li>
          <li>Flight and ground transportation logistics</li>
          <li>Accessibility and lodging research</li>
          <li>Airport navigation and baggage assistance</li>
        </ul>
        <ul class="included-list">
          <li>In-flight companion support</li>
          <li>Hotel and lodging assistance</li>
          <li>Family communication throughout the trip</li>
          <li>Medical-informed care when needed</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container cta-section__inner">
      <h2>Ready to get started?</h2>
      <p>Reach out today for a personalized quote — no obligation.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn--primary">Contact Us</a>
        <a href={`mailto:${site.email}`} class="btn btn--secondary">{site.email}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .process-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .process-step {
    display: grid;
    gap: 1.5rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .process-step {
      grid-template-columns: 5rem 1fr;
      align-items: start;
    }
  }

  .process-step__number {
    font-family: var(--font-serif);
    font-size: 3rem;
    color: var(--color-accent);
    line-height: 1;
  }

  .process-step h2 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .process-step p {
    color: var(--color-text-muted);
    max-width: 36rem;
  }

  .included-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
  }

  .included-list li {
    padding: 0.75rem 0;
    padding-left: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted);
    position: relative;
  }

  .included-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1.15rem;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  .cta-section__inner {
    text-align: center;
  }

  .cta-section h2 {
    font-size: clamp(2rem, 3vw, 2.75rem);
    margin-bottom: 0.75rem;
  }

  .cta-section p {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
</style>
