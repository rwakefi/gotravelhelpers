---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { site, executiveServices, images } from '../../data/site';

const executiveSchema = {
  '@context': 'https://schema.org',
  '@type': 'OfferCatalog',
  name: 'Executive Travel Concierge & Advisory Services',
  provider: {
    '@type': 'TravelAgency',
    name: site.name,
    url: 'https://gotravelhelpers.com',
  },
  itemListElement: executiveServices.map((service) => ({
    '@type': 'Service',
    name: service.title,
    description: service.description,
    serviceType: service.title,
    provider: { '@type': 'TravelAgency', name: site.name },
    areaServed: 'Worldwide',
  })),
};
---

<BaseLayout
  title="Executive Travel"
  description="VIP travel concierge and advisory services for busy professionals and high-profile clients. Elite airport lounge fast-track, VIP booking, and logistics coordination."
  schema={executiveSchema}
>
  <PageHero
    label="Premium Concierge Services"
    title="Elite travel concierge and advisory services"
    description="Bringing a personal touch to the lives of road warriors. And when it is time to transition from business to R&R, we work with you and your family to plan unforgettable vacations that make your time together count."
    image={{ src: "/images/beach-sunset.png", alt: "Luxury beach sunset with palm trees" }}
  />

  <section class="section section--alt intro-quote">
    <div class="container container--narrow">
      <div class="quote-card">
        <span class="section-label">A Note from Our Founder</span>
        <blockquote class="quote-card__text">
          "As business travel demands increase, I focus on bringing a personal, supportive touch to the lives of road warriors. Travel is about more than just the next meeting. When the time comes to step away, I collaborate with travelers and their families to plan vacations that turn R&R into unforgettable shared moments."
        </blockquote>
        <div class="quote-card__author">
          <strong>Cyndi Glidewell</strong>
          <span>Founder, Travel Helpers</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container services-list">
      {
        executiveServices.map((service, i) => (
          <article class={`service-row ${i % 2 === 1 ? 'service-row--reverse' : ''}`}>
            <div class="service-row__content">
              <h2>{service.title}</h2>
              <p>{service.description}</p>
            </div>
            <div class="service-row__visual">
              <img src={service.image} alt={service.imageAlt} width={400} height={300} loading="lazy" />
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section section--alt">
    <div class="container centered-cta">
      <h2>Seamless, stress-free executive travel</h2>
      <p>Contact us to arrange dedicated, high-discretion travel coordination and concierge support for your upcoming schedule.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn--primary">Request VIP Estimate</a>
        <a href={site.phoneHref} class="btn btn--secondary">{site.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .services-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .service-row {
    display: grid;
    gap: 2rem;
    align-items: center;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .service-row {
      grid-template-columns: 1fr auto;
    }

    .service-row--reverse {
      direction: rtl;
    }

    .service-row--reverse > * {
      direction: ltr;
    }
  }

  .service-row__content h2 {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    margin-bottom: 0.75rem;
  }

  .service-row__content p {
    color: var(--color-text-muted);
    max-width: 36rem;
  }

  .service-row__visual {
    width: 100%;
    max-width: 14rem;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .service-row__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .service-row__visual {
      max-width: 18rem;
    }
  }

  .centered-cta {
    text-align: center;
  }

  .centered-cta h2 {
    font-size: clamp(2rem, 3vw, 2.75rem);
    margin-bottom: 0.75rem;
  }

  .centered-cta p {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .container--narrow {
    max-width: 46rem;
  }

  .intro-quote {
    padding: 4.5rem 0;
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
  }

  .quote-card {
    text-align: center;
  }

  .quote-card .section-label {
    margin-bottom: 1.5rem;
  }

  .quote-card__text {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 2.5vw, 1.85rem);
    font-style: italic;
    line-height: 1.45;
    color: var(--color-text);
    margin: 0 0 2rem;
    position: relative;
    padding: 0 1rem;
  }

  .quote-card__author {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .quote-card__author strong {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .quote-card__author span {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
</style>
