---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site, services, images } from '../data/site';

const servicesSchema = {
  '@context': 'https://schema.org',
  '@type': 'OfferCatalog',
  name: 'Travel companion services',
  provider: {
    '@type': 'TravelAgency',
    name: site.name,
    url: 'https://gotravelhelpers.com',
  },
  itemListElement: services.map((service) => ({
    '@type': 'Service',
    name: service.title,
    description: service.description,
    serviceType: service.title,
    provider: { '@type': 'TravelAgency', name: site.name },
    areaServed: 'Worldwide',
  })),
};
---

<BaseLayout
  title="Services"
  description="Full-service travel companion support — airport, in-flight, door-to-door, lodging, planning, and medical travel assistance worldwide."
  schema={servicesSchema}
>
  <PageHero
    label="What we offer"
    title="Companion services for every leg of the journey"
    description="From the moment you leave home through every day of your adventure, Travel Helpers provides comprehensive companion support tailored to your needs."
    image={images.pageHero.services}
  />

  <section class="section">
    <div class="container services-list">
      {
        services.map((service, i) => (
          <article class={`service-row ${i % 2 === 1 ? 'service-row--reverse' : ''}`}>
            <div class="service-row__content">
              <h2>{service.title}</h2>
              <p>{service.description}</p>
            </div>
            <div class="service-row__visual">
              <img src={service.image} alt={service.imageAlt} width={400} height={300} loading="lazy" />
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section section--alt">
    <div class="container centered-cta">
      <h2>Every trip is unique</h2>
      <p>Contact us to discuss your itinerary and receive a personalized quote.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn--primary">Get a Quote</a>
        <a href={site.phoneHref} class="btn btn--secondary">{site.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .services-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .service-row {
    display: grid;
    gap: 2rem;
    align-items: center;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .service-row {
      grid-template-columns: 1fr auto;
    }

    .service-row--reverse {
      direction: rtl;
    }

    .service-row--reverse > * {
      direction: ltr;
    }
  }

  .service-row__content h2 {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    margin-bottom: 0.75rem;
  }

  .service-row__content p {
    color: var(--color-text-muted);
    max-width: 36rem;
  }

  .service-row__visual {
    width: 100%;
    max-width: 14rem;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .service-row__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .service-row__visual {
      max-width: 18rem;
    }
  }

  .centered-cta {
    text-align: center;
  }

  .centered-cta h2 {
    font-size: clamp(2rem, 3vw, 2.75rem);
    margin-bottom: 0.75rem;
  }

  .centered-cta p {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
</style>
