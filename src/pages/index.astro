---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, services, audiences, testimonials, stats, steps, images } from '../data/site';
---

<BaseLayout title={site.name}>
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__content">
        <p class="section-label">Worldwide travel companions</p>
        <h1>{site.motto}</h1>
        <p class="hero__lead">
          {site.description}
        </p>
        <div class="hero__actions">
          <a href="/contact" class="btn btn--primary">Get a Quote</a>
          <a href="/how-it-works" class="btn btn--secondary">How It Works</a>
        </div>
        <a href={site.phoneHref} class="hero__phone">{site.phone}</a>
      </div>
      <div class="hero__image">
        <img
          src={images.hero.src}
          alt={images.hero.alt}
          width={images.hero.width}
          height={images.hero.height}
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-label">Who we help</p>
      <h2 class="section-title">Travel made possible for everyone</h2>
      <p class="section-intro">
        Whether you are planning for yourself or a loved one, we provide the support that turns hesitation into confidence.
      </p>
      <div class="grid-2 audience-grid">
        {
          audiences.map((item) => (
            <article class="audience-card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <p class="section-label">Our services</p>
      <h2 class="section-title">Everything you need, door to door</h2>
      <div class="services-grid">
        {
          services.slice(0, 6).map((service) => (
            <article class="card">
              <h3>{service.title}</h3>
              <p>{service.description}</p>
            </article>
          ))
        }
      </div>
      <div class="section-cta">
        <a href="/services" class="btn btn--primary">View All Services</a>
      </div>
    </div>
  </section>

  <section class="section editorial">
    <div class="container editorial__grid">
      <div class="editorial__image">
        <img
          src={images.mission.src}
          alt={images.mission.alt}
          width={images.mission.width}
          height={images.mission.height}
          loading="lazy"
        />
      </div>
      <div class="editorial__content">
        <p class="section-label">Our mission</p>
        <h2>Companion support for every mile</h2>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. We believe travel should never be out of reach — whether the journey is for medical care or a long-awaited adventure.
        </p>
        <p>
          <strong>{site.founder.name}, {site.founder.credentials}</strong><br />
          {site.founder.title}, {site.name}
        </p>
        <a href="/about" class="btn btn--secondary">Our Story</a>
      </div>
    </div>
  </section>

  <section class="section section--dark stats">
    <div class="container stats__grid">
      {
        stats.map((stat) => (
          <div class="stat">
            <span class="stat__value">{stat.value}</span>
            <span class="stat__label">{stat.label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-label">How it works</p>
      <h2 class="section-title">Simple steps to stress-free travel</h2>
      <div class="steps-grid">
        {
          steps.map((step) => (
            <article class="step">
              <span class="step__number">{step.number}</span>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </article>
          ))
        }
      </div>
      <div class="section-cta">
        <a href="/how-it-works" class="btn btn--secondary">Learn More</a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <p class="section-label">Testimonials</p>
      <h2 class="section-title">Stories from the journey</h2>
      <div class="grid-3">
        {
          testimonials.map((item) => (
            <blockquote class="testimonial card">
              <p>&ldquo;{item.quote}&rdquo;</p>
              <footer>
                <strong>{item.name}</strong>
                <span>{item.location}</span>
              </footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section cta-banner">
    <div class="container cta-banner__inner">
      <div>
        <h2>Ready to plan your trip?</h2>
        <p>Contact us for a personalized quote. No obligation — just a conversation about how we can help.</p>
      </div>
      <div class="cta-banner__actions">
        <a href="/contact" class="btn btn--light">Get a Quote</a>
        <a href={site.phoneHref} class="btn btn--secondary cta-banner__phone">{site.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 3rem 0 0;
    overflow: hidden;
  }

  .hero__grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 960px) {
    .hero__grid {
      grid-template-columns: 1fr 1fr;
      min-height: calc(100vh - var(--header-height));
    }
  }

  .hero__content h1 {
    font-size: clamp(2.75rem, 5.5vw, 4.5rem);
    margin-bottom: 1.5rem;
  }

  .hero__lead {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin-bottom: 2rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .hero__phone {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .hero__image img {
    width: 100%;
    height: 100%;
    min-height: 24rem;
    object-fit: cover;
    border-radius: var(--radius);
  }

  .audience-grid {
    margin-top: 3rem;
  }

  .audience-card {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }

  .audience-card h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .audience-card p {
    color: var(--color-text-muted);
  }

  .services-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .section-cta {
    margin-top: 2.5rem;
    text-align: center;
  }

  .editorial__grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .editorial__grid {
      grid-template-columns: 1.1fr 1fr;
    }
  }

  .editorial__image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius);
  }

  .editorial__content h2 {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    margin-bottom: 1.25rem;
  }

  .editorial__content p {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .editorial__content .btn {
    margin-top: 1.5rem;
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .stats__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat__value {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.35rem;
  }

  .stat__label {
    font-size: 0.875rem;
    color: rgba(247, 245, 242, 0.65);
    letter-spacing: 0.04em;
  }

  .steps-grid {
    display: grid;
    gap: 2rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .steps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .steps-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .step__number {
    display: block;
    font-family: var(--font-serif);
    font-size: 2.5rem;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .step h3 {
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
  }

  .step p {
    font-size: 0.975rem;
    color: var(--color-text-muted);
  }

  .testimonial p {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-style: italic;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .testimonial footer {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-size: 0.875rem;
  }

  .testimonial footer span {
    color: var(--color-text-muted);
  }

  .cta-banner {
    background: var(--color-accent);
    color: #fff;
  }

  .cta-banner__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .cta-banner__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .cta-banner h2 {
    font-size: clamp(2rem, 3vw, 2.75rem);
    margin-bottom: 0.75rem;
  }

  .cta-banner p {
    opacity: 0.9;
    max-width: 32rem;
  }

  .cta-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .cta-banner__phone {
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
  }

  .cta-banner__phone:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }
</style>
