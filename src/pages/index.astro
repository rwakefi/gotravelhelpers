---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, services, audiences, recentAdventures, founderNote, images } from '../data/site';
---

<BaseLayout title={site.name}>
  <section class="hero hero--sky">
    <div class="hero__sky" aria-hidden="true">
      <div class="hero__sky-gradient"></div>
      <img class="hero__clouds" src="/images/sky-clouds.svg" alt="" width="1440" height="320" />
      <div class="hero__cloud hero__cloud--1"></div>
      <div class="hero__cloud hero__cloud--2"></div>
      <div class="hero__cloud hero__cloud--3"></div>
      <img class="hero__plane" src="/images/plane-silhouette.svg" alt="" width="64" height="32" />
    </div>
    <div class="container hero__grid">
      <div class="hero__content">
        <p class="section-label hero__label">Worldwide travel companions</p>
        <h1>{site.motto}</h1>
        <p class="hero__lead">
          {site.description}
        </p>
        <div class="hero__actions">
          <a href="/contact" class="btn btn--primary">Get a Quote</a>
          <a href="/how-it-works" class="btn btn--secondary hero__btn-secondary">How It Works</a>
        </div>
        <a href={site.phoneHref} class="hero__phone">{site.phone}</a>
      </div>
      <div class="hero__image">
        <img
          src={images.hero.src}
          alt={images.hero.alt}
          width={images.hero.width}
          height={images.hero.height}
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="section section--home">
    <div class="container">
      <p class="section-label">Who we help</p>
      <h2 class="section-title">Travel made possible for everyone</h2>
      <p class="section-intro">
        Whether you are planning for yourself or a loved one, we provide the support that turns hesitation into confidence.
      </p>
      <div class="grid-2 audience-grid">
        {
          audiences.map((item) => (
            <article class="audience-card">
              <div class="audience-card__image">
                <img src={item.image} alt={item.imageAlt} width={600} height={400} loading="lazy" />
              </div>
              <div class="audience-card__body">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--home section--alt">
    <div class="container">
      <p class="section-label">Our services</p>
      <h2 class="section-title">Everything you need, door to door</h2>
      <div class="services-grid">
        {
          services.slice(0, 6).map((service) => (
            <article class="card">
              <h3>{service.title}</h3>
              <p>{service.description}</p>
            </article>
          ))
        }
      </div>
      <div class="section-cta">
        <a href="/services" class="btn btn--primary">View All Services</a>
      </div>
    </div>
  </section>

  <section class="section cta-banner">
    <div class="container cta-banner__inner">
      <div>
        <h2>Ready to plan your trip?</h2>
        <p>Contact us for a personalized quote. No obligation — just a conversation about how we can help.</p>
      </div>
      <div class="cta-banner__actions">
        <a href="/contact" class="btn btn--light">Get a Quote</a>
        <a href={site.phoneHref} class="btn btn--secondary cta-banner__phone">{site.phone}</a>
      </div>
    </div>
  </section>

  <section class="section section--home">
    <div class="container">
      <p class="section-label">Recent adventures</p>
      <h2 class="section-title">Lots of TH travels lately!</h2>
      <p class="section-intro">
        From Caribbean cruises to Las Vegas and the Greek isles — here is a glimpse of where Travel Helpers has been making adventures possible.
      </p>
      <div class="grid-3 adventures-grid">
        {
          recentAdventures.map((trip) => (
            <article class="adventure-card card">
              <div class="adventure-card__image">
                <img src={trip.image} alt={trip.imageAlt} width={600} height={400} loading="lazy" />
              </div>
              <h3>{trip.title}</h3>
              <p>{trip.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--alt editorial editorial--note">
    <div class="container editorial__grid">
      <div class="editorial__content">
        <p class="section-label">Travel wisely</p>
        <h2>{founderNote.title}</h2>
        <p>{founderNote.intro}</p>
        <ul class="founder-note__list">
          {founderNote.points.map((point) => <li>{point}</li>)}
        </ul>
        <p><strong>{founderNote.closing}</strong></p>
        <p>
          <strong>{site.founder.name}, {site.founder.credentials}</strong><br />
          {site.founder.title}, {site.name}
        </p>
        <a href={site.phoneHref} class="btn btn--primary">Call {site.phone}</a>
      </div>
      <div class="founder-note__gallery">
        {
          founderNote.gallery.map((photo) => (
            <img src={photo.src} alt={photo.alt} width={400} height={300} loading="lazy" />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section--home {
    padding: 4.25rem 0;
  }

  .hero--sky {
    position: relative;
    padding: 2rem 0 4.25rem;
    overflow: hidden;
    background: linear-gradient(180deg, #d4e9f6 0%, #e3f2fa 28%, #eef7fc 55%, #f5fafc 82%, var(--color-bg) 100%);
  }

  .hero__sky {
    position: absolute;
    inset: 0;
    height: 100%;
    pointer-events: none;
    overflow: hidden;
  }

  .hero__sky-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      #cce5f4 0%,
      #e0f0fa 40%,
      rgba(247, 245, 242, 0) 100%
    );
  }

  .hero__plane {
    position: absolute;
    top: 12%;
    left: 58%;
    width: clamp(2.75rem, 5vw, 4rem);
    height: auto;
    border: none;
    opacity: 0.7;
    z-index: 2;
    animation: hero-plane-fly 42s linear infinite;
    pointer-events: none;
  }

  @keyframes hero-plane-fly {
    0% {
      transform: translate(55vw, 0) rotate(-6deg);
      opacity: 0;
    }
    8% {
      opacity: 0.65;
    }
    92% {
      opacity: 0.65;
    }
    100% {
      transform: translate(-35vw, 1.5rem) rotate(-6deg);
      opacity: 0;
    }
  }

  @media (min-width: 960px) {
    .hero__plane {
      top: 10%;
      left: auto;
      right: 6%;
      animation: hero-plane-fly-desktop 38s linear infinite;
    }

    @keyframes hero-plane-fly-desktop {
      0% {
        transform: translate(40vw, -0.5rem) rotate(-5deg);
        opacity: 0;
      }
      10% {
        opacity: 0.72;
      }
      90% {
        opacity: 0.72;
      }
      100% {
        transform: translate(-28vw, 1rem) rotate(-5deg);
        opacity: 0;
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__plane {
      animation: none;
      top: 8%;
      right: 8%;
      left: auto;
      opacity: 0.55;
      transform: rotate(-5deg);
    }
  }

  @media (max-width: 639px) {
    .hero__plane {
      top: 6%;
      left: auto;
      right: 4%;
      width: 2.5rem;
      animation: hero-plane-fly-mobile 36s linear infinite;
    }

    @keyframes hero-plane-fly-mobile {
      0% {
        transform: translate(30vw, 0) rotate(-6deg);
        opacity: 0;
      }
      12% {
        opacity: 0.55;
      }
      88% {
        opacity: 0.55;
      }
      100% {
        transform: translate(-25vw, 0.5rem) rotate(-6deg);
        opacity: 0;
      }
    }
  }

  .hero__clouds {
    position: absolute;
    bottom: -2rem;
    left: 50%;
    width: 120%;
    min-width: 60rem;
    max-width: none;
    height: auto;
    transform: translateX(-50%);
    opacity: 0.95;
    border: none;
  }

  .hero__cloud {
    position: absolute;
    background: #fff;
    border-radius: 50%;
    filter: blur(2px);
    opacity: 0.88;
    border: none;
  }

  .hero__cloud--1 {
    width: 12rem;
    height: 4rem;
    top: 18%;
    left: 8%;
    box-shadow:
      3rem 0 0 -0.5rem #fff,
      6rem 0.5rem 0 -1rem rgba(255, 255, 255, 0.9);
  }

  .hero__cloud--2 {
    width: 16rem;
    height: 5rem;
    top: 8%;
    right: 12%;
    box-shadow:
      -4rem 0.25rem 0 -0.75rem #fff,
      -8rem 0 0 -1.25rem rgba(255, 255, 255, 0.85);
  }

  .hero__cloud--3 {
    width: 10rem;
    height: 3.5rem;
    top: 28%;
    left: 42%;
    opacity: 0.65;
    box-shadow: 2.5rem 0 0 -0.5rem rgba(255, 255, 255, 0.8);
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 960px) {
    .hero__grid {
      grid-template-columns: 1fr 1fr;
      min-height: calc(100vh - var(--header-height));
    }
  }

  .hero__label {
    font-size: clamp(1rem, 1.75vw, 1.25rem);
    letter-spacing: 0.12em;
    margin-bottom: 1.25rem;
  }

  .hero__content h1 {
    font-size: clamp(2.75rem, 5.5vw, 4.5rem);
    margin-bottom: 1.5rem;
  }

  .hero__lead {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin-bottom: 2rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .hero__phone {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .hero__btn-secondary {
    background: rgba(255, 255, 255, 0.65);
    border-color: rgba(20, 20, 20, 0.12);
  }

  .hero__btn-secondary:hover {
    background: #fff;
    border-color: rgba(20, 20, 20, 0.2);
  }

  .hero__image img {
    width: 100%;
    height: 100%;
    min-height: 24rem;
    object-fit: cover;
    border-radius: var(--radius);
  }

  .section-intro {
    margin-bottom: 0;
  }

  .audience-grid {
    margin-top: 2.5rem;
  }

  .audience-card {
    display: grid;
    gap: 1.5rem;
    padding: 1.75rem 0;
    border-top: 1px solid var(--color-border);
  }

  .audience-card:first-child {
    padding-top: 0;
    border-top: none;
  }

  @media (min-width: 640px) {
    .audience-card {
      grid-template-columns: 11rem 1fr;
      align-items: center;
    }
  }

  .audience-card__image {
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 3 / 2;
    box-shadow: var(--shadow);
  }

  .audience-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .audience-card h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .audience-card p {
    color: var(--color-text-muted);
  }

  .services-grid {
    display: grid;
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .section-cta {
    margin-top: 2rem;
    text-align: center;
  }

  .editorial__grid {
    display: grid;
    gap: 2.5rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .editorial__grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  .editorial__content h2 {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    margin-bottom: 1.25rem;
  }

  .editorial__content p {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .editorial__content .btn {
    margin-top: 1.5rem;
  }

  .adventures-grid {
    margin-top: 2.5rem;
  }

  .adventure-card {
    padding: 0;
    overflow: hidden;
  }

  .adventure-card__image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .adventure-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .adventure-card h3 {
    font-size: 1.25rem;
    padding: 1.25rem 1.25rem 0.5rem;
  }

  .adventure-card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    padding: 0 1.25rem 1.25rem;
    margin: 0;
  }

  .editorial--note .editorial__grid {
    align-items: start;
  }

  .founder-note__list {
    margin: 1.25rem 0;
    padding-left: 1.25rem;
    color: var(--color-text-muted);
  }

  .founder-note__list li {
    margin-bottom: 0.75rem;
  }

  .founder-note__gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .founder-note__gallery img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius);
  }

  .cta-banner {
    padding: 3.25rem 0;
    background: var(--color-accent);
    color: #fff;
  }

  .cta-banner__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .cta-banner__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .cta-banner h2 {
    font-size: clamp(2rem, 3vw, 2.75rem);
    margin-bottom: 0.75rem;
  }

  .cta-banner p {
    opacity: 0.9;
    max-width: 32rem;
  }

  .cta-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .cta-banner__phone {
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
  }

  .cta-banner__phone:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }
</style>
