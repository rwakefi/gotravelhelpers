---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, services, audiences, recentAdventures, founderNote, images, stats, testimonials } from '../data/site';
---

<BaseLayout title={site.name}>
  <section class="hero hero--sky">
    <div class="hero__sky" aria-hidden="true">
      <div class="hero__sky-gradient"></div>
      <img class="hero__clouds" src="/images/sky-clouds.svg" alt="" width="1440" height="320" />
      <div class="hero__cloud hero__cloud--1"></div>
      <div class="hero__cloud hero__cloud--2"></div>
      <div class="hero__cloud hero__cloud--3"></div>
      <img class="hero__plane" src="/images/plane-silhouette.svg" alt="" width="64" height="32" />
    </div>
    <div class="container hero__grid">
      <div class="hero__content">
        <div class="hero__headline">
          <a href="/" class="hero__logo-mark">
            <img
              src={site.logo.src}
              alt={site.logo.alt}
              width={site.logo.width}
              height={site.logo.height}
              loading="eager"
              decoding="async"
            />
          </a>
          <h1>{site.motto}</h1>
        </div>
        <p class="hero__lead">
          {site.description}
        </p>
        <div class="hero__actions">
          <a href="/contact" class="btn btn--primary">Get an Estimate</a>
          <a href="/how-it-works" class="btn btn--secondary hero__btn-secondary">How It Works</a>
        </div>
        <a href={site.phoneHref} class="hero__phone">{site.phone}</a>
      </div>
      <div class="hero__image">
        <img
          src={images.hero.src}
          alt={images.hero.alt}
          width={images.hero.width}
          height={images.hero.height}
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="section section--home">
    <div class="container">
      <p class="section-label">Who we help</p>
      <h2 class="section-title">Travel made possible for everyone</h2>
      <p class="section-intro">
        Whether you are planning for yourself or a loved one, we provide the support that turns hesitation into confidence.
      </p>
      <div class="grid-2 audience-grid">
        {
          audiences.map((item) => (
            <article class="audience-card">
              <div class="audience-card__image">
                <img
                  src={item.image}
                  alt={item.imageAlt}
                  width={600}
                  height={400}
                  loading="lazy"
                  style={item.image.includes('zurich') ? 'object-position: center 18%;' : ''}
                />
              </div>
              <div class="audience-card__body">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--home section--alt">
    <div class="container">
      <p class="section-label">Our services</p>
      <h2 class="section-title">Tailored travel support for every journey</h2>
      
      <div class="grid-2 services-pillars">
        <div class="services-pillar-card card">
          <h3>Executive & Luxury Concierge</h3>
          <p>High-discretion travel coordination and VIP concierge services for busy professionals and luxury travelers. Seamless scheduling, lounges, and luxury vacations.</p>
          <ul class="services-pillar-list">
            <li>VIP Fast-Track & Airport Lounge Access</li>
            <li>Real-Time Itinerary & Transit Coordination</li>
            <li>Bespoke Leisure & Wellness Curation</li>
            <li>Strict Client Discretion & Ground Liaison</li>
          </ul>
        </div>
        
        <div class="services-pillar-card card">
          <h3>Assisted Travel Services</h3>
          <p>Comprehensive companion support for seniors, families, and travelers with medical or mobility needs. We handle every detail from your door to your destination.</p>
          <ul class="services-pillar-list">
            <li>Airport & In-Flight Companionship</li>
            <li>Door-to-Door Journey Support</li>
            <li>Medical Travel Coordination (RN-Led)</li>
            <li>Lodging & Daily Adventure Assistance</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-banner">
    <div class="container cta-banner__inner">
      <div>
        <h2>Ready to plan your trip?</h2>
        <p>Contact us for a personalized estimate. No obligation — just a conversation about how we can help.</p>
      </div>
      <div class="cta-banner__actions">
        <a href="/contact" class="btn btn--light">Get an Estimate</a>
        <a href={site.phoneHref} class="btn btn--secondary cta-banner__phone">{site.phone}</a>
      </div>
    </div>
  </section>

  <section class="section section--home trust-bar">
    <div class="container">
      <div class="trust-bar__grid">
        <div class="trust-bar__item">
          <span class="trust-bar__value">RN-Led</span>
          <span class="trust-bar__label">Certified Registered Nurse founder</span>
        </div>
        <div class="trust-bar__divider"></div>
        <div class="trust-bar__item">
          <span class="trust-bar__value">BSN + MBA</span>
          <span class="trust-bar__label">Clinical & business expertise</span>
        </div>
        <div class="trust-bar__divider"></div>
        <div class="trust-bar__item">
          <span class="trust-bar__value">Worldwide</span>
          <span class="trust-bar__label">Companion coverage — any destination</span>
        </div>
        <div class="trust-bar__divider"></div>
        <div class="trust-bar__item">
          <span class="trust-bar__value">Fora Travel</span>
          <span class="trust-bar__label">Affiliated with a global advisor network</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--home section--alt testimonials-section">
    <div class="container">
      <p class="section-label">Client stories</p>
      <h2 class="section-title">What our travelers say</h2>
      <p class="section-intro">
        Real experiences from real clients — both executive travelers and families who trusted us with their most meaningful journeys.
      </p>
      <div class="testimonials-grid">
        {
          testimonials.map((item) => (
            <blockquote class="testimonial-card">
              <div class="testimonial-card__stars" aria-label="5 stars">★★★★★</div>
              <p class="testimonial-card__quote">&ldquo;{item.quote}&rdquo;</p>
              <footer class="testimonial-card__footer">
                <span class="testimonial-card__author">{item.author}</span>
                <span class="testimonial-card__location">{item.location}</span>
              </footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--home">
    <div class="container">
      <p class="section-label">Recent adventures</p>
      <h2 class="section-title">Lots of TH travels lately!</h2>
      <p class="section-intro">
        From Caribbean cruises to Las Vegas and the Greek isles — here is a glimpse of where Travel Helpers has been making adventures possible.
      </p>
      <div class="grid-3 adventures-grid">
        {
          recentAdventures.map((trip) => (
            <article class="adventure-card card">
              <div class="adventure-card__image">
                <img src={trip.image} alt={trip.imageAlt} width={600} height={400} loading="lazy" />
              </div>
              <h3>{trip.title}</h3>
              <p>{trip.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--alt editorial editorial--note">
    <div class="container editorial__grid">
      <div class="editorial__content">
        <p class="section-label">Travel wisely</p>
        <h2>{founderNote.title}</h2>
        <p>{founderNote.intro}</p>
        <ul class="founder-note__list">
          {founderNote.points.map((point) => <li>{point.text}</li>)}
        </ul>
        <p><strong>{founderNote.closing}</strong></p>
        <p>
          <strong>{site.founder.name}, {site.founder.credentials}</strong><br />
          {site.founder.title}, {site.name}
        </p>
        <a href={site.phoneHref} class="btn btn--primary">Call {site.phone}</a>
      </div>
      <div class="founder-note__gallery">
        {
          founderNote.gallery.map((photo) => (
            <img src={photo.src} alt={photo.alt} width={400} height={300} loading="lazy" />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section--home {
    padding: 4.25rem 0;
  }

  .hero--sky + .section--home {
    padding-top: 2.5rem;
  }

  .hero--sky {
    position: relative;
    padding: 1.5rem 0 2.5rem;
    overflow: hidden;
    background: linear-gradient(180deg, #d4e9f6 0%, #e3f2fa 28%, #eef7fc 55%, #f5fafc 82%, var(--color-bg) 100%);
  }

  .hero__sky {
    position: absolute;
    inset: 0;
    height: 100%;
    pointer-events: none;
    overflow: hidden;
  }

  .hero__sky-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      #cce5f4 0%,
      #e0f0fa 40%,
      rgba(247, 245, 242, 0) 100%
    );
  }

  .hero__plane {
    position: absolute;
    top: 12%;
    left: 58%;
    width: clamp(2.75rem, 5vw, 4rem);
    height: auto;
    border: none;
    opacity: 0.7;
    z-index: 2;
    animation: hero-plane-fly 42s linear infinite;
    pointer-events: none;
  }

  @keyframes hero-plane-fly {
    0% {
      transform: translate(55vw, 0) rotate(-6deg);
      opacity: 0;
    }
    8% {
      opacity: 0.65;
    }
    92% {
      opacity: 0.65;
    }
    100% {
      transform: translate(-35vw, 1.5rem) rotate(-6deg);
      opacity: 0;
    }
  }

  @media (min-width: 960px) {
    .hero__plane {
      top: 10%;
      left: auto;
      right: 6%;
      animation: hero-plane-fly-desktop 38s linear infinite;
    }

    @keyframes hero-plane-fly-desktop {
      0% {
        transform: translate(40vw, -0.5rem) rotate(-5deg);
        opacity: 0;
      }
      10% {
        opacity: 0.72;
      }
      90% {
        opacity: 0.72;
      }
      100% {
        transform: translate(-28vw, 1rem) rotate(-5deg);
        opacity: 0;
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__plane {
      animation: none;
      top: 8%;
      right: 8%;
      left: auto;
      opacity: 0.55;
      transform: rotate(-5deg);
    }
  }

  @media (max-width: 639px) {
    .hero__plane {
      top: 6%;
      left: auto;
      right: 4%;
      width: 2.5rem;
      animation: hero-plane-fly-mobile 36s linear infinite;
    }

    @keyframes hero-plane-fly-mobile {
      0% {
        transform: translate(30vw, 0) rotate(-6deg);
        opacity: 0;
      }
      12% {
        opacity: 0.55;
      }
      88% {
        opacity: 0.55;
      }
      100% {
        transform: translate(-25vw, 0.5rem) rotate(-6deg);
        opacity: 0;
      }
    }
  }

  .hero__clouds {
    position: absolute;
    bottom: -2rem;
    left: 50%;
    width: 120%;
    min-width: 60rem;
    max-width: none;
    height: auto;
    transform: translateX(-50%);
    opacity: 0.95;
    border: none;
  }

  .hero__cloud {
    position: absolute;
    background: #fff;
    border-radius: 50%;
    filter: blur(2px);
    opacity: 0.88;
    border: none;
  }

  .hero__cloud--1 {
    width: 12rem;
    height: 4rem;
    top: 18%;
    left: 8%;
    box-shadow:
      3rem 0 0 -0.5rem #fff,
      6rem 0.5rem 0 -1rem rgba(255, 255, 255, 0.9);
  }

  .hero__cloud--2 {
    width: 16rem;
    height: 5rem;
    top: 8%;
    right: 12%;
    box-shadow:
      -4rem 0.25rem 0 -0.75rem #fff,
      -8rem 0 0 -1.25rem rgba(255, 255, 255, 0.85);
  }

  .hero__cloud--3 {
    width: 10rem;
    height: 3.5rem;
    top: 28%;
    left: 42%;
    opacity: 0.65;
    box-shadow: 2.5rem 0 0 -0.5rem rgba(255, 255, 255, 0.8);
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 960px) {
    .hero__grid {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }

  .hero__headline {
    display: inline-block;
    max-width: 100%;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .hero__logo-mark {
    display: block;
    margin-bottom: 1.25rem;
  }

  .hero__logo-mark img {
    display: block;
    width: clamp(11.55rem, 23.1vw, 16.8rem);
    height: auto;
    max-width: 100%;
    margin-inline: auto;
    object-fit: contain;
  }

  .hero__headline h1 {
    font-size: clamp(2.75rem, 5.5vw, 4.5rem);
    margin-bottom: 0;
    text-align: left;
  }

  .hero__lead {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin-bottom: 2rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .hero__phone {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .hero__btn-secondary {
    background: rgba(255, 255, 255, 0.65);
    border-color: rgba(20, 20, 20, 0.12);
  }

  .hero__btn-secondary:hover {
    background: #fff;
    border-color: rgba(20, 20, 20, 0.2);
  }

  @media (max-width: 959px) {
    .hero__grid {
      padding-top: 1.75rem;
    }

    .hero__content {
      text-align: center;
    }

    .hero__headline {
      display: block;
    }

    .hero__headline h1 {
      text-align: center;
    }

    .hero__lead {
      margin-left: auto;
      margin-right: auto;
    }

    .hero__actions {
      justify-content: center;
    }
  }

  .hero__image img {
    width: 100%;
    height: 100%;
    min-height: 24rem;
    object-fit: cover;
    border-radius: var(--radius);
  }

  .section-intro {
    margin-bottom: 0;
  }

  .audience-grid {
    margin-top: 2.5rem;
  }

  .audience-card {
    display: grid;
    gap: 1.5rem;
    padding: 1.75rem 0;
    border-top: 1px solid var(--color-border);
  }

  .audience-card:first-child {
    padding-top: 0;
    border-top: none;
  }

  @media (min-width: 640px) {
    .audience-card {
      grid-template-columns: 11rem 1fr;
      align-items: center;
    }
  }

  .audience-card__image {
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 3 / 2;
    box-shadow: var(--shadow);
  }

  .audience-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .audience-card h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .audience-card p {
    color: var(--color-text-muted);
  }

  .services-grid {
    display: grid;
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .section-cta {
    margin-top: 2rem;
    text-align: center;
  }

  .editorial__grid {
    display: grid;
    gap: 2.5rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .editorial__grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  .editorial__content h2 {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    margin-bottom: 1.25rem;
  }

  .editorial__content p {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .editorial__content .btn {
    margin-top: 1.5rem;
  }

  .adventures-grid {
    margin-top: 2.5rem;
  }

  .adventure-card {
    padding: 0;
    overflow: hidden;
  }

  .adventure-card__image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .adventure-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .adventure-card h3 {
    font-size: 1.25rem;
    padding: 1.25rem 1.25rem 0.5rem;
  }

  .adventure-card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    padding: 0 1.25rem 1.25rem;
    margin: 0;
  }

  .editorial--note .editorial__grid {
    align-items: start;
  }

  .founder-note__list {
    margin: 1.25rem 0;
    padding-left: 1.25rem;
    color: var(--color-text-muted);
  }

  .founder-note__list li {
    margin-bottom: 0.75rem;
  }

  .founder-note__gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .founder-note__gallery img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius);
  }

  .cta-banner {
    padding: 3.25rem 0;
    background: var(--color-accent);
    color: #fff;
  }

  .cta-banner__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .cta-banner__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .cta-banner h2 {
    font-size: clamp(2rem, 3vw, 2.75rem);
    margin-bottom: 0.75rem;
  }

  .cta-banner p {
    opacity: 0.9;
    max-width: 32rem;
  }

  .cta-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .cta-banner__phone {
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
  }

  .cta-banner__phone:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  /* Services Pillars Layout */
  .services-pillars {
    margin-top: 2.5rem;
  }

  .services-pillar-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    height: 100%;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
  }

  .services-pillar-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-accent);
    color: #fff;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }

  .services-pillar-badge--executive {
    background: #2a2420;
  }

  .services-pillar-card h3 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    font-family: var(--font-serif);
  }

  .services-pillar-card p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .services-pillar-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    width: 100%;
  }

  .services-pillar-list li {
    font-size: 0.9375rem;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .services-pillar-list li::before {
    content: "✓";
    color: var(--color-accent);
    font-weight: bold;
  }

  .services-pillar-btn {
    width: 100%;
    text-align: center;
  }

  /* ── Trust / Credentials Bar ── */
  .trust-bar {
    padding-top: 0;
    padding-bottom: 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .trust-bar__grid {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .trust-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.75rem 2.5rem;
    flex: 1 1 11rem;
  }

  .trust-bar__divider {
    width: 1px;
    height: 3rem;
    background: var(--color-border);
    flex-shrink: 0;
    display: none;
  }

  @media (min-width: 640px) {
    .trust-bar__divider {
      display: block;
    }
  }

  .trust-bar__value {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1.2;
    margin-bottom: 0.3rem;
  }

  .trust-bar__label {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* ── Testimonials ── */
  .testimonials-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  @media (min-width: 640px) {
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .testimonials-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .testimonial-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: 0 2px 12px rgba(20, 20, 20, 0.05);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .testimonial-card:hover {
    box-shadow: 0 6px 24px rgba(20, 20, 20, 0.1);
    transform: translateY(-2px);
  }

  .testimonial-card__stars {
    color: #c8a96e;
    font-size: 1rem;
    letter-spacing: 0.05em;
  }

  .testimonial-card__quote {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text);
    font-style: italic;
    flex-grow: 1;
    margin: 0;
  }

  .testimonial-card__footer {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .testimonial-card__author {
    font-weight: 600;
    font-size: 0.875rem;
