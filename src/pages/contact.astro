---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site, images } from '../data/site';

const formAction = `https://formsubmit.co/${encodeURIComponent(site.email)}`;
const formReturnUrl = `https://${site.domain}/contact/?sent=1`;
const formSent = Astro.url.searchParams.get('sent') === '1';
---

<BaseLayout title="Contact" description={`Contact Travel Helpers for a personalized travel companion estimate. Call ${site.phone} or email ${site.email}.`}>
  <PageHero
    label="Get in touch"
    title="Let's plan your journey"
    description="Tell us about your trip and we'll provide a personalized estimate. No obligation — just a conversation about how we can help."
    image={images.pageHero.contact}
  />

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-info">
        <h2>Contact information</h2>
        <ul class="contact-list">
          <li>
            <strong>Phone</strong>
            <a href={site.phoneHref}>{site.phone}</a>
          </li>
          <li>
            <strong>Email</strong>
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </li>
          <li>
            <strong>Service area</strong>
            <span>{site.serviceArea}</span>
          </li>
        </ul>

        <div class="contact-social">
          <h3>Follow us</h3>
          <div class="social-links">
            <a href={site.social.facebook} target="_blank" rel="noopener noreferrer">Facebook</a>
          </div>
        </div>
      </div>

      <form class="contact-form card" action={formAction} method="POST">
        <input type="hidden" name="_subject" value="New estimate request — Travel Helpers website" />
        <input type="hidden" name="_next" value={formReturnUrl} />
        <input type="hidden" name="_captcha" value="true" />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <h2>Request an estimate</h2>

        {
          formSent && (
            <p class="form-success" role="status">
              Thank you — your message was sent. We'll reply to you at the email you provided, usually within one business day.
            </p>
          )
        }

        <div class="form-group">
          <label for="name">Full name</label>
          <input type="text" id="name" name="name" required autocomplete="name" />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>

        <div class="form-group">
          <label for="phone">Phone</label>
          <input type="tel" id="phone" name="phone" autocomplete="tel" />
        </div>

        <div class="form-group">
          <label for="traveler">Who is traveling?</label>
          <select id="traveler" name="traveler">
            <option value="">Select one</option>
            <option value="self">Myself</option>
            <option value="parent">A parent or family member</option>
            <option value="other">Someone else</option>
          </select>
        </div>

        <div class="form-group">
          <label for="trip-type">Trip type</label>
          <select id="trip-type" name="trip-type">
            <option value="">Select one</option>
            <option value="medical">Medical travel</option>
            <option value="bucket-list">Bucket-list trip</option>
            <option value="relocation">Relocation</option>
            <option value="family">Family visit</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="route">Departure & destination</label>
          <input type="text" id="route" name="route" placeholder="e.g. Fayetteville, AR to Rochester, MN" />
        </div>

        <div class="form-group">
          <label for="dates">Travel dates</label>
          <input type="text" id="dates" name="dates" placeholder="Approximate dates or 'flexible'" />
        </div>

        <div class="form-group">
          <label for="message">Message / special needs</label>
          <textarea id="message" name="message" placeholder="Tell us about the traveler and any special requirements"></textarea>
        </div>

        <button type="submit" class="btn btn--primary">Send Inquiry</button>
        <p class="form-note">
          Or call <a href={site.phoneHref}>{site.phone}</a> or email <a href={`mailto:${site.email}`}>{site.email}</a> directly.
        </p>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 960px) {
    .contact-grid {
      grid-template-columns: 1fr 1.4fr;
    }
  }

  .contact-info h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
  }

  .contact-list li {
    margin-bottom: 1.25rem;
  }

  .contact-list strong {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .contact-list a {
    color: var(--color-accent);
    font-weight: 500;
  }

  .contact-social h3 {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .social-links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .social-links a {
    font-size: 0.9375rem;
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact-form h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .form-success {
    padding: 1rem 1.125rem;
    margin-bottom: 1.5rem;
    background: rgba(158, 59, 59, 0.08);
    border: 1px solid rgba(158, 59, 59, 0.2);
    color: var(--color-text);
  }

  .form-note a {
    color: var(--color-accent);
  }
</style>
