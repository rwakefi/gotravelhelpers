---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site, images } from '../data/site';
---

<BaseLayout title="About" description="Meet Cyndi Glidewell, RN, MBA — founder of Travel Helpers, providing compassionate travel companion services worldwide.">
  <PageHero
    label="About us"
    title="Compassionate care meets world-class travel support"
    description="Travel Helpers was founded on a simple belief: everyone should be able to travel — for medical care, family, or the trip of a lifetime."
    image={images.pageHero.about}
  />

  <section class="section">
    <div class="container about-grid">
      <div class="about-grid__image">
        <img
          src={images.about.src}
          alt={images.about.alt}
          width={images.about.width}
          height={images.about.height}
          loading="lazy"
        />
      </div>
      <div class="about-grid__content prose">
        <h2>{site.founder.name}, {site.founder.credentials}</h2>
        <p>
          {site.motto} Travel Helpers provides services ranging from extra hands during air travel to non-critical medical assistance while traveling — and we have expanded to stay with you throughout your adventure, not just to get you there.
        </p>
        <p>
          Recent trips have taken us on a Royal Caribbean cruise through the Eastern Caribbean, to Las Vegas with an 88-year-old client and his son, and on Norwegian Cruise Line through Greece. Every trip reminds us how many people need just a little help to achieve their travel dreams.
        </p>
        <p>
          While you are on your vacation, we are working — navigating ports, excursions, cobblestone streets, and the details that make travel safe and enjoyable. Call Travel Helpers to hire your travel assistant today.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <p class="section-label">Our approach</p>
      <h2 class="section-title">Personal, professional, and present</h2>
      <div class="grid-3 approach-grid">
        <article class="card">
          <h3>Led by a registered nurse</h3>
          <p>Medical expertise informs every companion plan, ensuring travelers with health needs receive informed, attentive support.</p>
        </article>
        <article class="card">
          <h3>Tailored to you</h3>
          <p>No two travelers are alike. We customize every detail — from airport assistance to multi-day trip companionship.</p>
        </article>
        <article class="card">
          <h3>On the adventure</h3>
          <p>We stay with you at your destination — on excursions, at historic sites, and throughout your trip — so you can travel with confidence.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container quote-block">
      <blockquote>
        <p>&ldquo;{site.motto}&rdquo;</p>
        <footer>— {site.founder.name}, {site.founder.credentials}</footer>
      </blockquote>
      <a href="/contact" class="btn btn--primary">Start a Conversation</a>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 0.9fr 1.1fr;
    }
  }

  .about-grid__image img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius);
  }

  .about-grid__content h2 {
    font-size: 2rem;
    margin-bottom: 1.25rem;
  }

  .approach-grid {
    margin-top: 2.5rem;
  }

  .quote-block {
    text-align: center;
    max-width: 40rem;
    margin-inline: auto;
  }

  .quote-block blockquote p {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-style: italic;
    margin-bottom: 1rem;
  }

  .quote-block footer {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    display: block;
  }
</style>
